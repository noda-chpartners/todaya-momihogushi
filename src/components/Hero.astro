---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import hero01 from '../assets/images/hero01.png';
import hero02 from '../assets/images/hero02.png';
import hero03 from '../assets/images/hero03.png';
---

<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="hero__backdrop" aria-hidden="true"></div>
  <div class="hero__copy js-hero-copy">
    <p class="hero__kicker">MOMIHOGUSHI / NAGOYA</p>
    <p class="hero__lead">灯りを落とした一席の空間で、<br class="hero__break" />からだを休める静かな時間を。</p>
    <div class="hero__actions">
      <a class="button button--primary" href={site.lineUrl} target="_blank" rel="noreferrer">
        <span class="button__label">LINEでお問い合わせ</span>
        <span class="button__arrow" aria-hidden="true"></span>
      </a>
      <a class="text-link" href={site.phoneHref}>
        <span class="text-link__label">{site.phoneDisplay}</span>
      </a>
    </div>
  </div>

  <div class="hero__visual js-hero-visual">
    <figure class="hero__main-frame">
      <Image
        class="hero__main-image media"
        src={hero02}
        alt="行灯が並ぶ、とだ家の店内"
        widths={[480, 750, 1200]}
        sizes="(max-width: 768px) 100vw, 55vw"
        format="webp"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
    <figure class="hero__layer-frame hero__layer-frame--top js-parallax">
      <Image
        class="hero__layer-image media"
        src={hero01}
        alt="竹と白砂でしつらえた店内"
        widths={[360, 640, 960]}
        sizes="(max-width: 768px) 45vw, 28vw"
        format="webp"
      />
    </figure>
    <figure class="hero__layer-frame hero__layer-frame--bottom js-parallax">
      <Image
        class="hero__layer-image media"
        src={hero03}
        alt="とだ家の施術室"
        widths={[360, 640, 960]}
        sizes="(max-width: 768px) 45vw, 28vw"
        format="webp"
      />
    </figure>
    <p class="hero__vertical">一席だけの、静かな空間</p>
  </div>

  <div class="hero__facts" aria-label="店舗概要">
    <div class="hero__fact">
      <span class="hero__fact-label">OPEN</span>
      <span class="hero__fact-value">平日 {site.weekdayHours}</span>
    </div>
    <div class="hero__fact">
      <span class="hero__fact-label">ACCESS</span>
      <span class="hero__fact-value">{site.station}</span>
    </div>
    <div class="hero__fact">
      <span class="hero__fact-label">ROOM</span>
      <span class="hero__fact-value">{site.seats}</span>
    </div>
  </div>
  <a class="hero__scroll" href="#concept">
    <span class="hero__scroll-label">SCROLL</span>
    <span class="hero__scroll-line" aria-hidden="true"></span>
  </a>
</section>
