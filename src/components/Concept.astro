---
import { Image } from 'astro:assets';
import SectionHeading from './SectionHeading.astro';
import hero from '../assets/images/hero.png';
import counseling from '../assets/images/counseling.png';
---

<section class="concept section" id="concept" aria-labelledby="concept-title">
  <div class="container concept__grid">
    <div class="concept__heading">
      <SectionHeading eyebrow="とだ家について" id="concept-title">
        からだを休める、<br class="section-heading__break" />静かな時間。
      </SectionHeading>
    </div>
    <div class="concept__copy js-reveal">
      <p class="concept__text">名古屋市名東区一社の、もみほぐし専門店。</p>
      <p class="concept__text">一席の空間に灯るやわらかな明かりの中で、ゆっくりとお過ごしください。</p>
    </div>
    <figure class="concept__photo concept__photo--large js-reveal js-parallax">
      <Image
        class="concept__image media"
        src={hero}
        alt="行灯と器が置かれた、とだ家の店内"
        widths={[480, 750, 1200]}
        sizes="(max-width: 768px) 100vw, 70vw"
        format="webp"
      />
    </figure>
    <figure class="concept__photo concept__photo--small js-reveal">
      <Image
        class="concept__image media"
        src={counseling}
        alt="店内でお話をうかがう様子"
        widths={[360, 640, 900]}
        sizes="(max-width: 768px) 70vw, 35vw"
        format="webp"
      />
      <figcaption class="concept__caption">カウンセリング</figcaption>
    </figure>
  </div>
</section>
