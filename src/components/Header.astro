---
import { site } from '../data/site';

const navLinks = [
  { href: '#reservation', label: 'ご予約' },
  { href: '#info', label: 'アクセス' },
  { href: '#menu', label: '料金' },
  { href: '#contact', label: 'お問い合わせ' },
];
---

<header class="header" data-header>
  <h1>
    <a class="header__brand" href="#top" aria-label="ページの先頭へ">
      <span class="header__brand-small">もみほぐし専門店</span>
      <span class="header__brand-main">とだ家</span>
    </a>
  </h1>
  <nav class="header__nav" aria-label="ページ内メニュー">
    {navLinks.map((link) => (
      <a class="header__link" href={link.href}>{link.label}</a>
    ))}
  </nav>
  <a class="button button--header" href={site.hotpepperUrl} target="_blank" rel="noreferrer">
    <span class="button__label">ホットペッパー予約</span>
    <span class="button__arrow" aria-hidden="true"></span>
  </a>
  <button
    type="button"
    class="header__menu-toggle"
    aria-expanded="false"
    aria-controls="mobile-nav"
    data-menu-toggle
  >
    <span class="header__menu-icon" aria-hidden="true"></span>
    <span class="visually-hidden" data-menu-toggle-label>メニューを開く</span>
  </button>
</header>

<div class="mobile-nav" id="mobile-nav" data-mobile-nav>
  <nav class="mobile-nav__panel" aria-label="ページ内メニュー">
    {navLinks.map((link) => (
      <a class="mobile-nav__link" href={link.href} data-mobile-nav-link>{link.label}</a>
    ))}
    <a class="mobile-nav__cta" href={site.hotpepperUrl} target="_blank" rel="noreferrer" data-mobile-nav-link>
      ホットペッパー予約
    </a>
  </nav>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const toggleLabel = document.querySelector<HTMLElement>('[data-menu-toggle-label]');

  if (toggle && panel) {
    const closeMenu = () => {
      panel.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('nav-open');
      if (toggleLabel) toggleLabel.textContent = 'メニューを開く';
    };

    const openMenu = () => {
      panel.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('nav-open');
      if (toggleLabel) toggleLabel.textContent = 'メニューを閉じる';
    };

    toggle.addEventListener('click', () => {
      const isOpen = panel.classList.contains('is-open');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    panel.querySelectorAll<HTMLAnchorElement>('[data-mobile-nav-link]').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeMenu();
    });

    window.matchMedia('(min-width: 901px)').addEventListener('change', (event) => {
      if (event.matches) closeMenu();
    });
  }
</script>
