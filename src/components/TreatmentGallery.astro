---
import { Image } from 'astro:assets';
import { treatmentImages } from '../data/site';
---

<section class="gallery section" aria-label="施術風景">
  <div class="gallery__intro container js-reveal">
    <p class="gallery__eyebrow">施術風景</p>
    <p class="gallery__title">手から伝わる、<br class="gallery__break" />静かなリズム。</p>
  </div>
  <div class="gallery__viewport">
    <div class="gallery__track js-gallery-track">
      {treatmentImages.map((image, index) => (
        <figure class:list={['gallery-card', { 'gallery-card--tall': index % 3 === 1 }] }>
          <Image
            class="gallery-card__image media"
            src={image.src}
            alt={image.alt}
            widths={[320, 480, 720]}
            sizes="(max-width: 768px) 70vw, 23vw"
            format="webp"
          />
          <figcaption class="gallery-card__caption">とだ家 / {String(index + 1).padStart(2, '0')}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
